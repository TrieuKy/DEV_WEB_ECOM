@model IEnumerable<MyWebProject.Models.Student>

@{
    ViewData["Title"] = "Danh sách sinh viên";
}

<div class="text-center">
    <h2 class="display-4">Danh sách Sinh viên</h2>
</div>

<table class="table table-striped table-bordered mt-4">
    <thead class="table-dark">
        <tr>
            <th>Mã SV</th>
            <th>Họ và Tên</th>
            <th>Ngành học</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.Id</td>
                <td>@student.Name</td>
                <td>@student.Major</td>
            </tr>
        }
    </tbody>
</table>
